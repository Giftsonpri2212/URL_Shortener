NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12
FREE_PLAN_URL_QUOTA=100
PRO_PLAN_URL_QUOTA=10000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=url_shortener
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MAX_POOL=20

# Optional for Render managed PostgreSQL:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional for Render managed Redis:
# REDIS_URL=redis://default:pass@host:6379/0

CACHE_DEFAULT_TTL_SECONDS=86400
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION_SECONDS=3600
ANALYTICS_QUEUE_NAME=analytics-events
